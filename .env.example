# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────────────────────
# Docker local: postgresql://constractor:constractor@localhost:5432/constractor_dev
# Production:   postgresql://user:pass@host:5432/constractor_prod
DATABASE_URL=postgresql://constractor:constractor@localhost:5432/constractor_dev

# ── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Change these in production — must be long random strings
ACCESS_TOKEN_SECRET=dev-access-secret-change-in-prod
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-prod
ACCESS_TOKEN_EXPIRES_IN=900        # 15 minutes (seconds)
REFRESH_TOKEN_EXPIRES_IN=2592000   # 30 days (seconds)

# ── Provider Switches — ALL false = zero-cost local dev ───────────────────────
USE_REAL_AI=false
USE_REAL_STORAGE=false
USE_REAL_QUEUE=false
USE_REAL_REALTIME=false

# ── AI Provider (only needed when USE_REAL_AI=true) ──────────────────────────
OPENAI_API_KEY=

# ── Storage (only needed when USE_REAL_STORAGE=true) ─────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
UPLOAD_DIR=./uploads

# ── Queue / Redis (only needed when USE_REAL_QUEUE=true) ─────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ── Client Apps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
