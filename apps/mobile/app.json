{
  "expo": {
    "name": "Constractor",
    "slug": "constractor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "constractor",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.constractor.app"
    },
    "android": {
      "package": "com.constractor.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
