{
  "expo": {
    "name": "Constractor",
    "slug": "constractor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "constractor",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B2B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.constractor.app"
    },
    "android": {
      "package": "com.constractor.app",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#FF6B2B"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        { "microphonePermission": "Allow Constractor to record voice messages." }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Constractor to access photos for field reports.",
          "cameraPermission": "Allow Constractor to take photos for field reports."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
